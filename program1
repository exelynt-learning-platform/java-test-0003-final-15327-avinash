import java.util.*;

class program1 {

  public static void patn(int n) {
    int start;

    for (int i = 0; i < n; i++) {

      if (i % 2 == 0) {
        start = 1;
      } else {
        start = 0;
      }

      for (int j = 0; j <= i; j++) {
        System.out.print(start + " ");
        start = 1 - start;
      }

      System.out.println();
    }
  }

  public static void main(String args[]) {
    int n = 6;
    patn(n);
  }
}
